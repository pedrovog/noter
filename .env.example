# --- Required ---
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
VAULT_PATH=/home/you/Documents/obsidian/vault

# --- LLM provider key (set the one matching your NOTER_MODEL) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional: vault subfolder for new notes (default: noter)
# NOTER_INBOX=noter

# --- Model selection (LiteLLM) ---
# Use provider-prefixed model strings. Default is anthropic/claude-sonnet-4-6.
# NOTER_MODEL=anthropic/claude-sonnet-4-6
# NOTER_MODEL=openai/gpt-4o
# NOTER_MODEL=gemini/gemini-2.0-flash
# NOTER_MODEL=deepseek/deepseek-chat
#
# Optional: NOTER_PROVIDER is prepended to a bare model name (no "/").
# e.g. NOTER_PROVIDER=openai + NOTER_MODEL=gpt-4o  ==  openai/gpt-4o
# NOTER_PROVIDER=

# Per-agent overrides (fall back to NOTER_MODEL):
NOTER_PLANNER_MODEL=anthropic/claude-sonnet-4-6
NOTER_SYNTHESIZER_MODEL=anthropic/claude-sonnet-4-6
NOTER_WRITER_MODEL=anthropic/claude-haiku-4-5-20251001
NOTER_LINKER_MODEL=anthropic/claude-haiku-4-5-20251001

# --- Local / self-hosted models (Ollama, vLLM, LM Studio, ...) ---
# Point NOTER_API_BASE at your server and use a local model string. No API key needed.
# NOTER_MODEL=ollama_chat/llama3.1
# NOTER_API_BASE=http://localhost:11434
